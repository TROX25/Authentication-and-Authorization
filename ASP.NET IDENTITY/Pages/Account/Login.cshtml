@page
@model ASP.NET_IDENTITY.Pages.Account.LoginModel
@{
}

<h3> User Login</h3>
<br />
<div class="container border" style="padding:20px">
    <form method="post">
        <div class="text-danger" asp-validation-summary="All"></div>
        <div class="row mb-3">
            <div class="col-2">
            <label asp-for="Cridential.Email"></label>
            </div>
            <div class="col-5">
                <input type="text" asp-for="Cridential.Email" class="form-control" />
                <span class="text-danger" asp-validation-for="Cridential.Email"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-2">
                <label asp-for="Cridential.Password"></label>
            </div>
            <div class="col-5">
                <input type="password" asp-for="Cridential.Password" class="form-control" />
                <span class="text-danger" asp-validation-for="Cridential.Password"></span>
            </div>
        </div>
        <div class="row mb-3 form-check">
            <div class="col-2">
                <input type="checkbox" asp-for="Cridential.RememberMe" class="form-check-input" />
                <label asp-for="Cridential.RememberMe" class="form-check-label"></label>
            </div>
            <div class="col-5">
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-2">
                <input type="submit" value="Login" class="btn btn-primary" />
            </div>
            <div class="col-5">
                
            </div>
        </div>
    </form>
</div>
